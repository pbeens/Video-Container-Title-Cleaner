{
  "name": "video-container-title-cleaner",
  "version": "0.2.0",
  "description": "Electron desktop app for scanning videos and removing container title metadata.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/renderer.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [
    "electron",
    "video",
    "metadata",
    "ffprobe"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.peter.videocontainertitlecleaner",
    "productName": "Video Container Title Cleaner",
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "icon": "build/icons/app.icns"
    },
    "win": {
      "icon": "build/icons/app.ico",
      "extraResources": [
        {
          "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
          "to": "bin/ffprobe.exe"
        },
        {
          "from": "node_modules/ffmpeg-static/ffmpeg.exe",
          "to": "bin/ffmpeg.exe"
        }
      ]
    },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.map"
    ]
  }
}
